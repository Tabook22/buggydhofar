# Production secrets — copy to .env and change all values before going live
KHAREEF_SECRET_KEY=change-this-secret-for-production
KHAREEF_TOKEN_HOURS=168

# Public URL used in booking QR codes and confirmation emails
PUBLIC_SITE_URL=https://buggydhofar.com

# Optional extra CORS origins (comma-separated)
# CORS_ORIGINS=https://staging.buggydhofar.com

# SMTP settings for booking confirmation emails (from info@buggydhofar.com)
# Always send through Hostinger SMTP (not PHP mail) so DKIM/SPF apply.
# SMTP_USER and SMTP_FROM must both be info@buggydhofar.com to avoid spoofing flags.
# Hostinger advanced settings for info@buggydhofar.com:
#   Outgoing (SMTP): smtp.hostinger.com — port 465 — SSL/TLS (SMTP_USE_SSL=true)
#   Incoming (IMAP): imap.hostinger.com — port 993 — SSL/TLS (for Gmail/Outlook apps only)
# Port 465 uses implicit SSL automatically. Use port 587 + SMTP_USE_TLS=true for STARTTLS instead.
# Leave SMTP_HOST empty in development — emails are saved to backend/sent_emails/

SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@buggydhofar.com
SMTP_PASSWORD=
SMTP_FROM=info@buggydhofar.com
SMTP_FROM_NAME=Buggy Dhofar
SMTP_USE_SSL=true
SMTP_USE_TLS=false
ADMIN_NOTIFY_EMAIL=info@buggydhofar.com

# AMWAL SmartBox online payments (never commit real values to git)
# AMWAL_MID=your-merchant-id
# AMWAL_TID=your-terminal-id
# AMWAL_SECRET_KEY=your-64-char-hex-merchant-secure-key
# AMWAL_ENV=uat
