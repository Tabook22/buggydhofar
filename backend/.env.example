# SMTP settings for booking confirmation emails (from info@buggydhofar.com)
# Leave SMTP_HOST empty in development — emails are saved to backend/sent_emails/

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=info@buggydhofar.com
SMTP_FROM_NAME=Buggy Dhofar
SMTP_USE_TLS=true
ADMIN_NOTIFY_EMAIL=info@buggydhofar.com
